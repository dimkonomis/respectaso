# RespectASO Pro — Environment Variables (Desktop App)
# Copy to .env (which is gitignored) and fill in your values.
# For respectaso-web env vars, see the respectaso-web repo.

# Django secret key (auto-generated on first run if empty)
SECRET_KEY=

# Skip license validation for Pro features (requires DEBUG=True)
# True  = bypass license check, full AI access for testing
# False = normal license check, shows locked preview when no license (default)
DEBUG_SKIP_LICENSE=False
